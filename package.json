{
  "name": "plane-docs",
  "version": "1.0.0",
  "description": "Plane Developer Documentation",
  "type": "module",
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "(git fetch --unshallow || true) && vitepress build docs",
